# Supabase — copy to .env.local and fill in from Dashboard → Connect (or Settings → API Keys).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# New publishable key (sb_publishable_...). Public + RLS-enforced, safe in the browser.
# Replaces the legacy `anon` key, which Supabase is deprecating.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY

# Server-only secret key (sb_secret_...). Replaces `service_role`. NEVER expose to the
# client and never prefix with NEXT_PUBLIC_. Only add if you need elevated server access.
# SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
